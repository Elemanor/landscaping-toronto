---
import Layout from '../layouts/Layout.astro';
import { Hero } from '../components/Hero';
import { ProjectCards } from '../components/ProjectCards';
import { Process } from '../components/Process';
import { Pricing } from '../components/Pricing';
import { FAQ } from '../components/FAQ';

// JSON-LD Schema for Local Business
const jsonLdLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "RenoNext Landscaping",
  "image": "https://example.com/og-landscaping.jpg",
  "url": "https://example.com/landscaping-toronto",
  "telephone": "+1-647-495-3588",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "1234 Yonge St",
    "addressLocality": "Toronto",
    "addressRegion": "ON", 
    "postalCode": "M4T 1W3",
    "addressCountry": "CA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 43.6532,
    "longitude": -79.3832
  },
  "areaServed": [
    {"@type": "City", "name": "Toronto"},
    {"@type": "City", "name": "Mississauga"},
    {"@type": "City", "name": "Vaughan"},
    {"@type": "City", "name": "Richmond Hill"},
    {"@type": "City", "name": "Markham"},
    {"@type": "City", "name": "Oakville"}
  ],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
    "opens": "08:00",
    "closes": "18:00"
  },
  "sameAs": [
    "https://g.page/your-gbp",
    "https://www.facebook.com/yourbrand",
    "https://www.instagram.com/yourbrand"
  ],
  "makesOffer": [
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Interlock Patios & Walkways",
        "serviceType": "Design & build interlocking patios and paths (ICPI practices)"
      }
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Driveways (Standard & Permeable)",
        "serviceType": "Concrete paver driveways; permeable interlocking systems"
      }
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Retaining Walls & Steps",
        "serviceType": "Segmental walls, stairs, landings"
      }
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Softscape & Trees",
        "serviceType": "Planting, sod, native gardens; tree protection coordination"
      }
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Lighting & Irrigation",
        "serviceType": "Low‑voltage lighting, smart irrigation"
      }
    },
    {
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": "Drainage & Grading",
        "serviceType": "Regrading, swales, downspout management"
      }
    }
  ]
};

// FAQ Schema
const jsonLdFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need a permit to remove a tree?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Many trees on private property and all street trees are protected; the City requires permits to injure/remove protected trees."
      }
    },
    {
      "@type": "Question",
      "name": "Can I widen my driveway?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Zoning regulates driveway width and location even if a building permit isn't required; check with Toronto Building first."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need a pool fence permit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. A pool enclosure permit is required and you must obtain a zoning certificate first."
      }
    },
    {
      "@type": "Question",
      "name": "Do you arrange utility locates?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We request Ontario One Call locates before any digging, as required by law."
      }
    }
  ]
};
---

<Layout title="Toronto Landscaping Design-Build | Interlock, Patios, Driveways | ICPI Certified">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdLocalBusiness)} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdFAQ)} />
    
    <!-- Preload critical fonts -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" as="style" />
    
    <!-- Meta tags for SEO -->
    <meta name="keywords" content="landscaping contractor Toronto, landscape design Toronto, interlock patio Toronto, driveway pavers Toronto, retaining walls Toronto, landscaping permits Toronto" />
    <meta name="author" content="RenoNext Landscaping" />
    
    <!-- Open Graph -->
    <meta property="og:image" content="https://example.com/og-landscaping.jpg" />
    <meta property="og:url" content="https://example.com/landscaping-toronto" />
  </Fragment>

  <main>
    <!-- Hero Section with compliance badges -->
    <Hero client:load />
    
    <!-- Project Cards with ICPI standards -->
    <ProjectCards client:idle />
    
    <!-- Process Section -->
    <Process client:visible />
    
    <!-- Pricing Section -->
    <Pricing client:visible />
    
    <!-- FAQ Section -->
    <FAQ client:visible />
    
    <!-- Trust Badges Section -->
    <section class="py-12 px-4 bg-white border-t">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-wrap justify-center items-center gap-8">
          <div class="text-center">
            <img src="/api/placeholder/120/60" alt="Landscape Ontario" class="h-12 mx-auto mb-2" />
            <p class="text-xs text-gray-600">Member</p>
          </div>
          <div class="text-center">
            <img src="/api/placeholder/120/60" alt="WSIB" class="h-12 mx-auto mb-2" />
            <p class="text-xs text-gray-600">WSIB Cleared</p>
          </div>
          <div class="text-center">
            <img src="/api/placeholder/120/60" alt="ICPI" class="h-12 mx-auto mb-2" />
            <p class="text-xs text-gray-600">ICPI Certified</p>
          </div>
          <div class="text-center">
            <img src="/api/placeholder/120/60" alt="Better Business Bureau" class="h-12 mx-auto mb-2" />
            <p class="text-xs text-gray-600">A+ Rating</p>
          </div>
        </div>
      </div>
    </section>
    
    <!-- CTA Footer -->
    <section class="py-16 px-4 bg-gradient-to-r from-green-600 to-green-700 text-white">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Ready to Transform Your Outdoor Space?
        </h2>
        <p class="text-xl mb-8 opacity-95">
          Free on-site consultation • Detailed quotes • 5-year warranty
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="tel:647-495-3588" 
            class="bg-white text-green-700 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition"
          >
            📞 647-495-3588
          </a>
          <a 
            href="mailto:info@yourlandscaping.ca" 
            class="bg-green-800 text-white px-8 py-3 rounded-lg font-semibold hover:bg-green-900 transition"
          >
            ✉️ Get Free Quote
          </a>
        </div>
      </div>
    </section>
    
    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 py-8 px-4">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-3 gap-8 mb-8">
          <div>
            <h3 class="text-white font-semibold mb-3">Service Areas</h3>
            <p class="text-sm">
              Toronto, North York, Etobicoke, Scarborough, Mississauga, Vaughan, 
              Richmond Hill, Markham, Oakville, Burlington
            </p>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-3">Services</h3>
            <ul class="text-sm space-y-1">
              <li>Interlock Patios & Driveways</li>
              <li>Retaining Walls & Steps</li>
              <li>Landscape Design & Build</li>
              <li>Drainage & Grading</li>
            </ul>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-3">Certifications</h3>
            <ul class="text-sm space-y-1">
              <li>ICPI Certified Installer</li>
              <li>Landscape Ontario Member</li>
              <li>WSIB Clearance Certificate</li>
              <li>$2M Liability Insurance</li>
            </ul>
          </div>
        </div>
        <div class="text-center text-xs pt-8 border-t border-gray-800">
          <p>© 2025 RenoNext Landscaping. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </main>
</Layout>
